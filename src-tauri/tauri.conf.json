{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-settings/main/schema.json",
  "productName": "MapMig",
  "version": "1.1.0",
  "identifier": "com.mapmig.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "MapMig",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost",
      "dangerousDisableAssetCspModification": true
    }
  }
}
